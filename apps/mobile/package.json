{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@colanode/mobile",
  "version": "1.0.0",
  "author": "Colanode",
  "description": "Colanode mobile application",
  "main": "./index.js",
  "scripts": {
    "compile": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint app src --ext .ts,.tsx --max-warnings 0",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:editor": "vite build --config vite.editor.config.js",
    "dev:editor": "vite --config vite.editor.config.js"
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.4.1",
    "react-native-webview": "^13.12.5",
    "@tanstack/react-query": "^5.80.7",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-document-picker": "^55.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "~19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "babel-preset-expo": "~54.0.10",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "vite": "^6.3.5",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "private": true
}
